{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tricon Bank Transactions Flat Schema",
  "description": "Flat array of bank statement transactions for Tricon Transportation, Inc. QOE analysis",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id", "date", "year", "month", "account", "account_number",
      "amount", "type", "description", "bucket", "confidence",
      "reasoning", "statement_file", "source_file", "extraction_method",
      "extracted_at"
    ],
    "properties": {
      "id": {
        "type": "integer",
        "description": "Unique sequential identifier"
      },
      "date": {
        "type": "string",
        "format": "date",
        "description": "Transaction date in YYYY-MM-DD format"
      },
      "year": {
        "type": "string",
        "description": "Transaction year (YYYY)"
      },
      "month": {
        "type": "string",
        "description": "Transaction month (MM)"
      },
      "account": {
        "type": "string",
        "description": "Account name",
        "enum": ["BMO-TTICorp", "BMO-TTIPark", "CNB-TTICorp2", "TK-Investments", "TWS-Warehouse"]
      },
      "account_number": {
        "type": "string",
        "description": "Bank account number"
      },
      "amount": {
        "type": "number",
        "description": "Transaction amount in USD"
      },
      "type": {
        "type": "string",
        "description": "Transaction direction",
        "enum": ["deposit", "withdrawal", "check", "fee", "transfer"]
      },
      "description": {
        "type": "string",
        "description": "Raw transaction description from statement"
      },
      "check_number": {
        "type": ["string", "null"],
        "description": "Check number if applicable (parsed from description)"
      },
      "reference_number": {
        "type": ["string", "null"],
        "description": "Bank reference / transaction ID for reconciliation with QB (future use)"
      },
      "bucket": {
        "type": "string",
        "description": "Classification bucket",
        "enum": ["Revenue", "COGS", "OPEX-Non Payroll", "Payroll", "Financing", "Vendor Payment", ""]
      },
      "confidence": {
        "type": "string",
        "description": "Classification confidence level",
        "enum": ["High", "Medium", "Low", ""]
      },
      "reasoning": {
        "type": "string",
        "description": "Explanation for classification"
      },
      "statement_file": {
        "type": "string",
        "description": "Source PDF filename"
      },
      "source_file": {
        "type": "string",
        "description": "Full path to source PDF"
      },
      "extraction_method": {
        "type": "string",
        "description": "OCR/model used for extraction"
      },
      "extracted_at": {
        "type": "string",
        "format": "date-time",
        "description": "ISO timestamp of extraction"
      }
    }
  }
}
